OPENAI_API_KEY=your_api_key_here

APP_NAME=Async LLM Platform
ENVIRONMENT=dev
LOG_LEVEL=INFO
OPENAI_MODEL=gpt-4o-mini

MAX_CONCURRENCY = 5
MAX_RETRIES = 3
BACKOFF_BASE_SECONDS = 0.5
REQUEST_TIMEOUT_SECONDS = 20.0

REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/async_llm

ESTIMATED_INPUT_TOKEN_MULTIPLIER=1.4
ESTIMATED_OUTPUT_TOKENS = 300
INPUT_TOKEN_USD_PER_1M = 0.15
OUTPUT_TOKEN_USD_PER_1M = 0.60